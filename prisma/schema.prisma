generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(CLIENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProfile      ClientProfile?
  ticketsCreated     Ticket[]                  @relation("TicketCreatedBy")
  filesUploaded      ManagedFile[]             @relation("FileUploadedBy")
  projectsCreated    Project[]                 @relation("ProjectCreatedBy")
  engagementsCreated ClientServiceEngagement[] @relation("EngagementCreatedBy")
}

model ClientProfile {
  id          String       @id @default(cuid())
  userId      String       @unique
  companyName String
  phone       String?
  website     String?
  status      ClientStatus @default(ACTIVE)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects    Project[]
  tickets     Ticket[]
  fileFolders FileFolder[]
  files       ManagedFile[]
  engagements ClientServiceEngagement[]
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Project {
  id          String          @id @default(cuid())
  projectCode String          @unique
  name        String
  description String?
  status      ProjectStatus   @default(PLANNING)
  priority    ProjectPriority @default(MEDIUM)
  progress    Int             @default(0)

  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  engagementId String?
  engagement   ClientServiceEngagement? @relation(fields: [engagementId], references: [id], onDelete: SetNull)

  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets     Ticket[]
  fileFolders FileFolder[]
  files       ManagedFile[]

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@index([createdById])
  @@index([engagementId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CLIENT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id          String         @id @default(cuid())
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)

  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("TicketCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

enum FileCategory {
  DELIVERABLE
  DOCUMENT
  ASSET
  REPORT
  CONTRACT
  OTHER
}

enum FileStatus {
  ACTIVE
  ARCHIVED
}

model FileFolder {
  id   String @id @default(cuid())
  name String

  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files ManagedFile[]

  @@index([clientId])
  @@index([projectId])
}

model ManagedFile {
  id              String       @id @default(cuid())
  displayName     String
  originalName    String
  storageKey      String       @unique
  mimeType        String
  sizeBytes       BigInt
  category        FileCategory @default(OTHER)
  status          FileStatus   @default(ACTIVE)
  visibleToClient Boolean      @default(true)
  description     String?

  version        Int          @default(1)
  replacesFileId String?      @unique
  replacesFile   ManagedFile? @relation("FileVersions", fields: [replacesFileId], references: [id], onDelete: SetNull)
  newerVersion   ManagedFile? @relation("FileVersions")

  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  folderId String?
  folder   FileFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  uploadedById String
  uploadedBy   User   @relation("FileUploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([folderId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// Module 1 — approved Phase 2 additions
// ============================================================

enum BillingType {
  ONE_TIME
  RECURRING
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum DiscountType {
  NONE
  PERCENT
  FLAT
}

enum EngagementStatus {
  PENDING
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

model ServiceCategory {
  id             String  @id @default(cuid())
  key            String  @unique
  name           String
  description    String?
  kpiTemplateKey String?
  sortOrder      Int     @default(0)
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services Service[]

  @@index([isActive])
  @@index([sortOrder])
}

model Service {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?
  isActive    Boolean @default(true)

  categoryId String
  category   ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plans       ServicePlan[]
  engagements ClientServiceEngagement[]

  @@index([categoryId])
  @@index([isActive])
}

model ServicePlan {
  id           String        @id @default(cuid())
  name         String
  billingType  BillingType
  billingCycle BillingCycle?
  basePrice    Decimal       @db.Decimal(12, 2)
  currency     String
  isActive     Boolean       @default(true)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  features    PlanFeature[]
  engagements ClientServiceEngagement[]

  @@unique([serviceId, name])
  @@index([serviceId])
  @@index([isActive])
}

model PlanFeature {
  id          String  @id @default(cuid())
  label       String
  description String?
  sortOrder   Int     @default(0)

  planId String
  plan   ServicePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId, sortOrder])
}

model ClientServiceEngagement {
  id   String @id @default(cuid())
  name String

  billingType  BillingType
  billingCycle BillingCycle?

  /// The client's CURRENT contracted rate. ADMIN may update this at any
  /// time. LOCKED INVARIANT for future Module 4 (Invoicing): once an
  /// invoice line item has been generated from this engagement, that line
  /// item copies this value ONCE and never re-reads it. Updating this
  /// field must NEVER alter any previously issued invoice. Module 4 must
  /// not implement any code path that recalculates a historical invoice
  /// total from this field or from ServicePlan.basePrice.
  price    Decimal @db.Decimal(12, 2)
  currency String

  discountType  DiscountType @default(NONE)
  discountValue Decimal?     @db.Decimal(12, 2)
  taxRate       Decimal?     @db.Decimal(5, 2)

  paymentTermsDays Int              @default(15)
  status           EngagementStatus @default(PENDING)

  startDate   DateTime?
  endDate     DateTime?
  renewalDate DateTime?

  cancelledAt        DateTime?
  cancellationReason String?

  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Restrict)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  planId String?
  plan   ServicePlan? @relation(fields: [planId], references: [id], onDelete: Restrict)

  createdById String?
  createdBy   User?   @relation("EngagementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]

  @@index([clientId])
  @@index([serviceId])
  @@index([planId])
  @@index([status])
  @@index([renewalDate])
  @@index([endDate])
  @@index([status, renewalDate])
}
