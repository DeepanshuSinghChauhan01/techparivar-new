generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(CLIENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientProfile  ClientProfile?
  ticketsCreated Ticket[]       @relation("TicketCreatedBy")
  filesUploaded  ManagedFile[]  @relation("FileUploadedBy")
}

model ClientProfile {
  id          String       @id @default(cuid())
  userId      String       @unique
  companyName String
  phone       String?
  website     String?
  status      ClientStatus @default(ACTIVE)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects    Project[]
  tickets     Ticket[]
  fileFolders FileFolder[]
  files       ManagedFile[]
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus   @default(PLANNING)
  priority    ProjectPriority @default(MEDIUM)

  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  startDate DateTime?
  dueDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets     Ticket[]
  fileFolders FileFolder[]
  files       ManagedFile[]

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CLIENT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id          String         @id @default(cuid())
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)

  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("TicketCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

enum FileCategory {
  DELIVERABLE
  DOCUMENT
  ASSET
  REPORT
  CONTRACT
  OTHER
}

enum FileStatus {
  ACTIVE
  ARCHIVED
}

model FileFolder {
  id   String @id @default(cuid())
  name String

  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files ManagedFile[]

  @@index([clientId])
  @@index([projectId])
}

model ManagedFile {
  id              String       @id @default(cuid())
  displayName     String
  originalName    String
  storageKey      String       @unique
  mimeType        String
  sizeBytes       BigInt
  category        FileCategory @default(OTHER)
  status          FileStatus   @default(ACTIVE)
  visibleToClient Boolean      @default(true)
  description     String?

  version        Int          @default(1)
  replacesFileId String?      @unique
  replacesFile   ManagedFile? @relation("FileVersions", fields: [replacesFileId], references: [id], onDelete: SetNull)
  newerVersion   ManagedFile? @relation("FileVersions")

  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  folderId String?
  folder   FileFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  uploadedById String
  uploadedBy   User   @relation("FileUploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([projectId])
  @@index([folderId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
}
